{
  "name": "com.ethanthompson.keymapp-layers",
  "version": "1.0.0",
  "description": "Switch ZSA keyboard layers from Stream Deck",
  "author": "Ethan Thompson",
  "main": "installer/main.js",
  "scripts": {
    "build": "rollup --config rollup.config.mjs",
    "watch": "rollup --config rollup.config.mjs --watch",
    "download-kontroll": "node scripts/download-kontroll.mjs",
    "pack": "npm run build && node scripts/pack-plugin.mjs",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist": "npm run build && electron-builder",
    "installer:dev": "npm run build && electron ."
  },
  "devDependencies": {
    "@elgato/streamdeck": "^2.0.4",
    "@rollup/plugin-commonjs": "^25.0.8",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^25.6.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "rollup": "^4.60.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "fs-extra": "^11.2.0"
  }
}
